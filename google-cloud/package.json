{
	"name": "@trustknots/google-cloud",
	"version": "0.1.0",
	"description": "",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": "./lib/index.js"
	},
	"scripts": {
		"build": "tsc",
		"format": "biome format --write ./src/**/*.ts",
		"lint": "biome lint ./src/**/*.ts",
		"test": "node --import tsx --test test/**/*.spec.ts",
		"test:ci": "node --import tsx --test --experimental-test-coverage \"test/**/*.spec.ts\"",
		"test:all": "node --import tsx --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 \"test/**/*.spec.ts\"",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "Apache-2.0",
	"packageManager": "pnpm@10.30.3",
	"dependencies": {
		"@google-cloud/kms": "5.4.0",
		"@google-cloud/secret-manager": "^6.1.1",
		"@trustknots/vcknots": "workspace:*",
		"firebase-admin": "13.6.1",
		"zod": "4.3.6"
	}
}
